module Snap.Value exposing
    ( Value(..)
    , encodeValue
    , valueDecoder
    )

import Json.Decode as Decode exposing (Decoder)
import Json.Encode as Encode exposing (Value)


type Value
    = Text String
    | Count Int


valueDecoder : Decode.Decoder Value
valueDecoder =
    Decode.oneOf
        [ Decode.map Text Decode.string
        , Decode.map Count Decode.int
        ]


encodeValue : Value -> Value
encodeValue value =
    case value of
        Text inner ->
            Encode.string inner

        Count inner ->
            Encode.int inner
