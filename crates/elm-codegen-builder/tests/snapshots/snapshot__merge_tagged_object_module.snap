source: crates/elm-codegen-builder/tests/snapshot.rs
expression: rendered
---
module Snap.Tagged exposing
    ( Action(..)
    , Address
    , actionDecoder
    , addressDecoder
    , encodeAction
    , encodeAddress
    )

import Json.Decode as Decode exposing (Decoder)
import Json.Decode.Pipeline exposing (required)
import Json.Encode as Encode exposing (Value)


type alias Address =
    { line1 : String
    , city : String
    }


addressDecoder : Decode.Decoder Address
addressDecoder =
    Decode.succeed Address
        |> required "line1" Decode.string
        |> required "city" Decode.string


encodeAddress : Address -> Value
encodeAddress value =
    Encode.object
        [ ( "line1", Encode.string value.line1 )
        , ( "city", Encode.string value.city )
        ]


type Action
    = UpdateAddress Address
    | Noop


actionDecoder : Decode.Decoder Action
actionDecoder =
    Decode.field "action" Decode.string
        |> Decode.andThen
            (\tag ->
                case tag of
                    "UpdateAddress" ->
                        Decode.map UpdateAddress addressDecoder

                    "Noop" ->
                        Decode.succeed Noop

                    _ ->
                        Decode.fail ("Unknown Action: " ++ tag)
            )


encodeAction : Action -> Value
encodeAction value =
    case value of
        UpdateAddress inner ->
            mergeTaggedObject "action" "UpdateAddress" (encodeAddress inner)

        Noop ->
            Encode.object [ ( "action", Encode.string "Noop" ) ]


mergeTaggedObject : String -> String -> Value -> Value
mergeTaggedObject tagKey tagValue inner =
    Encode.object (( tagKey, Encode.string tagValue ) :: Result.withDefault [] (Decode.decodeValue (Decode.keyValuePairs Decode.value) inner))
